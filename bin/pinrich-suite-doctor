#!/usr/bin/env bash
# pinrich-suite-doctor — non-blocking prerequisite check.
# Invoked by the SessionStart hook (with `|| true`) and runnable by hand.
# Prints warnings only; never exits non-zero so it can't break a session.
set -uo pipefail

miss=0

# pinrich-cycle helper scripts deployed?
if [ ! -f "$HOME/.claude/pinrich-cycle/dashboard.mjs" ]; then
  echo "⚠ pinrich-suite: cycle helper scripts not deployed — run 'pinrich-suite-setup'"
  miss=1
fi

# qa-verify runtime installed at the path the skill expects?
if [ ! -d "$HOME/.claude/skills/qa-verify/runtime/node_modules" ]; then
  echo "⚠ pinrich-suite: qa-verify Playwright runtime not installed — run 'pinrich-suite-setup'"
  miss=1
fi

# jq present? (the SessionStart state-pump hook needs it)
if ! command -v jq >/dev/null 2>&1; then
  echo "⚠ pinrich-suite: 'jq' not found — the cycle state-pump SessionStart hook will be a no-op until installed"
  miss=1
fi

# design-fidelity-check env vars?
if [ -z "${PINRICH_GATE_DIR:-}" ] || [ -z "${PINRICH_GATE_PY:-}" ]; then
  echo "⚠ pinrich-suite: design-fidelity-check needs PINRICH_GATE_DIR + PINRICH_GATE_PY (see README)"
  miss=1
fi

[ "$miss" -eq 0 ] && echo "✓ pinrich-suite: prerequisites OK"
exit 0
